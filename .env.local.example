# Copy to .env.local and fill in from your Supabase project settings (API section).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...) — the app reads it under this name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key

# The app does NOT need a service-role / secret key. Only add one if you write a
# privileged server-side admin script — and use a revocable `sb_secret_...` key,
# not the legacy service_role JWT.
# SUPABASE_SECRET_KEY=sb_secret_...
